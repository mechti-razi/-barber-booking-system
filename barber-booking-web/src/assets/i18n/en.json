    "faq": {
      "title": "Help & FAQ",
      "subtitle": "Common questions answered",
      "q1": "How do I book an appointment?",
      "a1": "Go to Shops from the navigation, choose a barber shop, select a barber and a service, pick your preferred date and time slot, then confirm your booking. You will receive a confirmation instantly.",
      "q2": "Can I cancel my appointment?",
      "a2": "Yes. Open My Appointments from the profile menu, find your booking, and tap Cancel. Cancellations are free if made at least 1 hour before the appointment time.",
      "q3": "How do I enable appointment reminders?",
      "a3": "Go to your Profile and find 'Appointment Reminders' in the Support section. Tap the toggle to enable push notifications. You will be reminded 24 hours and 1 hour before each appointment.",
      "q4": "Is my personal data secure?",
      "a4": "Yes. All data is transmitted over HTTPS and stored securely. We never sell your personal information to third parties. See our Privacy Policy for full details.",
      "q5": "How do I contact support?",
      "a5": "For any issue not covered here, reach out to us at mechtirazi@gmail.com or call +216 24 060 251. We typically respond within 24 hours."
    },
    "privacy": {
      "title": "Privacy Policy",
      "subtitle": "How we handle your data",
      "s1title": "Data We Collect",
      "s1body": "We collect your name, email address, phone number, and booking history to provide the service. We may also collect device information and usage data to improve the app experience.",
      "s2title": "How We Use It",
      "s2body": "Your data is used to manage your bookings, send appointment reminders, and improve the platform. We do not use your data for advertising purposes.",
      "s3title": "Data Sharing",
      "s3body": "We do not sell your personal data. We share only the minimum necessary information with the barber shop you book with (name, phone, appointment details). We may use trusted service providers to operate the platform under strict data agreements.",
      "s4title": "Your Rights",
      "s4body": "You have the right to access, correct, or delete your personal data at any time. You can also request a copy of your data or withdraw consent. Contact us at mechtirazi@gmail.com or call +216 24 060 251 to exercise your rights.",
      "s5title": "Data Retention",
      "s5body": "We retain your account data for as long as your account is active. Booking history is kept for 12 months after the appointment date. You can request deletion at any time."
    },
